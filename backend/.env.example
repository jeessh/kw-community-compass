# Supabase Postgres connection (Project Settings -> Database -> Connection string -> URI)
# Note the driver prefix: postgresql+psycopg
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cookie
COOKIE_NAME=kwcc_session
COOKIE_SECURE=false

# CORS (your Next.js dev origin)
FRONTEND_ORIGIN=http://localhost:3000
