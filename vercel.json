{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    {
      "src": "backend/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "backend/app/**" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ],
  "env": { "ROOT_PATH": "/api" }
}
